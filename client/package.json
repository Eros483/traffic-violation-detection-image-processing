{
  "name": "btp-enforcement-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Traffic enforcement console for Bengaluru Traffic Police — consumes the detection API.",
  "scripts": {
    "dev": "vite",
