# ----- environment variables template @ .env.example -----

# Kaggle credentials for downloading datasets (make data)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# Groq API Key for optional LLM vision capabilities
GROQ_API_KEY=your_groq_api_key

# YouTube cookie authentication for yt-dlp (see yt-dlp wiki on cookies)
# Set to a browser name like "chrome", "firefox", or "brave" to auto-extract
# YOUTUBE_COOKIES_BROWSER=chrome
# Or point to a Netscape-format cookies.txt file
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt