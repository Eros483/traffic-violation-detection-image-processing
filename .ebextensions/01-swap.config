# ----- 1GB swap file for t3.micro (1GB RAM) to prevent OOM during model loading @ .ebextensions/01-swap.config -----
# Elastic Beanstalk runs commands before the Docker container starts.

commands:
  01-create-swap:
    command: |
      if [ ! -f /swapfile ]; then
        fallocate -l 1G /swapfile
        chmod 600 /swapfile
        mkswap /swapfile
        swapon /swapfile
        echo '/swapfile none swap sw 0 0' >> /etc/fstab
      fi
    test: test ! -f /swapfile
